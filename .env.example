# ── Vercel Deployment ──────────────────────────────────────────────────────────
# Get from: https://vercel.com/account/tokens
VERCEL_TOKEN=

# Get from Vercel project → Settings → General
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
VERCEL_PROJECT_NAME=synthia-avatar

# ── Build flags (no secrets required for Vercel build) ────────────────────────
SKIP_ENV_VALIDATION=1

# ── EmailJS (optional — only needed at runtime, not build time) ───────────────
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
